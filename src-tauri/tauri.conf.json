{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SessionDex",
  "version": "0.1.0",
  "identifier": "io.sessiondex.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SessionDex",
        "width": 1180,
        "height": 780,
        "minWidth": 900,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage", "deb", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Desktop session manager for terminal AI assistants",
    "longDescription": "SessionDex is a lightweight desktop session manager for terminal AI assistants like Codex CLI and Claude Code."
  }
}
